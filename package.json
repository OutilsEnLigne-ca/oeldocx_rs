{
  "name": "oeldocx-rs",
  "version": "0.1.0",
  "description": "DOCX document editing engine for WASM",
  "main": "pkg/oeldocx_rs.js",
  "types": "pkg/oeldocx_rs.d.ts",
  "files": [
    "pkg/*"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg --out-name oeldocx_rs",
    "build:nodejs": "wasm-pack build --target nodejs --out-dir pkg --out-name oeldocx_rs",
    "build:bundler": "wasm-pack build --target bundler --out-dir pkg --out-name oeldocx_rs",
    "dev": "wasm-pack build --dev --target web --out-dir pkg --out-name oeldocx_rs"
  },
  "devDependencies": {
    "wasm-pack": "^0.12.1"
  }
}
